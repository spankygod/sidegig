{
  "name": "backend",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "src/app.ts",
  "scripts": {
    "test": "npm run build:ts && node --test \"dist/src/**/*.test.js\"",
    "start": "npm run build:ts && fastify start -l info dist/src/app.js",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:ts": "npm run clean && tsc",
    "watch:ts": "tsc -w",
    "dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/src/app.js",
    "db:seed": "node scripts/seed-marketplace.js",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:push": "drizzle-kit push",
    "drizzle:pull": "drizzle-kit pull",
    "drizzle:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/sensible": "^6.0.0",
    "@supabase/supabase-js": "^2.102.1",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.0.0",
    "jose": "^6.2.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "fastify-tsconfig": "^3.0.0",
    "typescript": "~5.9.2"
  }
}
